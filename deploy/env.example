# Copy to ~/.mac_studio_sniper/env and fill in. The watcher service loads
# this at start. Everything is optional — with none of it set, the watcher
# still runs and prints sightings to its log (console). chmod 600 this file.

# Telegram phone alerts (recommended). Get these from:
#   @BotFather -> /newbot -> token; then `telegram-setup --token <TOKEN>` prints the chat id.
# SNIPER_TELEGRAM_BOT_TOKEN=123456:ABC...
# SNIPER_TELEGRAM_CHAT_ID=123456789

# Optional SMS/voice escalation via Twilio.
# SNIPER_TWILIO_ACCOUNT_SID=AC...
# SNIPER_TWILIO_AUTH_TOKEN=...
# SNIPER_TWILIO_FROM=+1...
# SNIPER_TWILIO_TO=+1...

# Override which targets file the service watches (default: availability config).
# SNIPER_TARGETS=/absolute/path/to/mac_studio_sniper/targets.yaml
